# ==========================================
# VERISTAY LOCAL ENVIRONMENT VARIABLES
# ==========================================

# 1. Local Database Credentials (For your pgAdmin)
DB_USER=postgres
DB_PASS=1428

# 2. Cloud Database URL (Paste your Render URL here so you don't lose it)
DATABASE_URL=jdbc:postgresql://localhost:5432/veristay_db3

# 3. Security (If you decide to extract your JWT secret later)
JWT_SECRET=my_super_secure_veristay_secret_key

# 4. Cloudinary Keys (If you add image hosting later)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=